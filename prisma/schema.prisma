datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

type LocalizedString {
  en String
  pl String
}

model Experience {
  id           String          @id @default(auto()) @map("_id") @db.ObjectId
  company      String
  role         LocalizedString
  date         LocalizedString
  description  LocalizedString
  technologies String[]
  orderIndex   Int             @default(0)
}

model Education {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  degree        LocalizedString
  institution   LocalizedString
  period        LocalizedString
  thesisTitle   LocalizedString?
  github        String?
  description   LocalizedString?
  orderIndex    Int             @default(0)
}

model Certificate {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  title          LocalizedString
  organizer      LocalizedString
  date           LocalizedString
  description    LocalizedString
  certificateUrl LocalizedString?
  supplementUrl  LocalizedString?
  highlight      Boolean         @default(false)
  orderIndex     Int             @default(0)
}

type SkillItem {
  name        String
  description LocalizedString
  subcategory LocalizedString?
}

model SkillCategory {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  category   LocalizedString
  iconName   String
  description LocalizedString?
  items      SkillItem[]
  orderIndex Int         @default(0)
}

model Profile {
  id                 String          @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  title              LocalizedString
  description        LocalizedString
  availabilityStatus Boolean
  githubUrl          String
  linkedinUrl        String
  sourceCodeUrl      String
  cvUrl              LocalizedString
  skillsSummary      String[]
  email              String          @default("bartlomiejgromada97@gmail.com")
}

model Project {
  id           String          @id @default(auto()) @map("_id") @db.ObjectId
  title        LocalizedString
  description  LocalizedString
  technologies String[]
  githubUrl    String
  iconName     String
  featured     Boolean         @default(false)
  orderIndex   Int             @default(0)
}
